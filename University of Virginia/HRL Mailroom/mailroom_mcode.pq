let
    Source = Oracle.Database("ORACLEGOLD.WORLD", [Query="SELECT UNIQUE#(lf) ""ACTIVITYTRANLEDGER"".""TRANDATE"" AS ""TRANSDATE"",#(lf) ""PATRONINFO"".""LASTNAME"", #(lf) ""PATRONINFO"".""FIRSTNAME"", #(lf) ""ACTIVITYTRANLEDGER"".""PATRONID"" AS ""PATRONID"",#(lf) TO_CHAR( ""KEYMAPPINGINFO"".KEYVALUE) AS ""PIK ID"" ,#(lf)#(lf) #(lf) ""ACTIVITYTRANLEDGER"".""LOCATION"",#(lf) ""LOCATIONDESCRIPTION"".""LONGDES"" AS ""DOOR DESCRIPTION"" ,#(lf) ""ACTIVITYTRANLEDGER"".""REASONMSG""#(lf) FROM   ((""DIEBOLD"".""ACTIVITYTRANLEDGER_VR"" ""ACTIVITYTRANLEDGER"" #(lf) LEFT JOIN ""DIEBOLD"".""LOCATIONDESCRIPTION_VR"" ""LOCATIONDESCRIPTION"" #(lf) ON ""ACTIVITYTRANLEDGER"".""LOCATION""=""LOCATIONDESCRIPTION"".""LOCATION"") #(lf) LEFT JOIN ""DIEBOLD"".""KEYMAPPINGINFO"" ""KEYMAPPINGINFO"" #(lf) ON ""ACTIVITYTRANLEDGER"".""PATRONID""=""KEYMAPPINGINFO"".""PATRONID"") #(lf) LEFT JOIN ""DIEBOLD"".""PATRONINFO"" ""PATRONINFO"" #(lf) ON ""ACTIVITYTRANLEDGER"".""PATRONID""=""PATRONINFO"".""PATRONID""#(lf)#(lf) WHERE (""KEYMAPPINGINFO"".""MEDIATYPE"" IS  NULL  OR ""KEYMAPPINGINFO"".""MEDIATYPE""='-1') #(lf)#(lf)   AND to_number(to_char(""ACTIVITYTRANLEDGER"".""TRANDATE"", 'HH24')) BETWEEN 0 AND 24#(lf)   --AND ""KEYMAPPINGINFO"".""KEYVALUE"" = ANY(  '100473404', '302667675', '384289213', '590778891', '525424413' )#(lf)   AND   ""ACTIVITYTRANLEDGER"".""TRANDATE"" >= TRUNC(sysdate)-90#(lf)   AND  ""ACTIVITYTRANLEDGER"".""PATRONID"" IS NOT NULL#(lf)   --AND ""ACTIVITYTRANLEDGER"".""LOCATION"" = ANY(22505,10949,28875,10902,9222,9006,224008,15356,15358,134,35153,35154,38303,37920,38312,38332,38333,38334,38343,38344,25267,22517,2806,42812,42815,14443,43569,43569,25267,35134)#(lf)   AND ""ACTIVITYTRANLEDGER"".""LOCATION"" = 22505#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 10949#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 28875#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 10902#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 224008#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 15356#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 15358#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 35153#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 35154#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 38303#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 37920#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 38312#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 38332#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 38333#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 38334#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 38343#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 38344#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 25267#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 22517#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 2806#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 42812#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 42815#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 14443#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 43569#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 43569#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 25267#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 35134#(lf)    OR ""ACTIVITYTRANLEDGER"".""LOCATION"" = 42808#(lf)#(lf) GROUP BY ""ACTIVITYTRANLEDGER"".""TRANDATE"",  ""ACTIVITYTRANLEDGER"".""PATRONID"" , ""KEYMAPPINGINFO"".""PATRONID"", ""PATRONINFO"".""LASTNAME"", ""PATRONINFO"".""FIRSTNAME"", TO_CHAR(KEYVALUE), ""ACTIVITYTRANLEDGER"".""LOCATION"", #(lf) ""LOCATIONDESCRIPTION"".""LONGDES"", ""ACTIVITYTRANLEDGER"".""REASONMSG""#(lf)#(lf) ORDER BY 1 DESC#(lf)", HierarchicalNavigation=true])
in
